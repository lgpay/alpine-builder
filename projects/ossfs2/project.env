PROJECT_NAME=ossfs2
SOURCE_REPO=https://github.com/aliyun/ossfs.git
SOURCE_REF=main-v1
BUILD_SYSTEM=autotools
INSTALL_PREFIX=/usr
CONFIGURE_ARGS=''
BUILD_ARGS='-j$(nproc)'
INSTALL_ARGS=''
PACKAGE_DIRS='bin sbin lib lib64 include share local/bin local/lib local/lib64 local/include local/share'
APK_BUILD_DEPS='bash build-base git linux-headers autoconf automake libtool make pkgconf tar file ca-certificates binutils patch coreutils findutils grep sed gawk perl curl libcurl curl-dev libxml2-dev fuse3-dev openssl-dev zlib-dev'
POST_CLONE_HOOK='if [ -f src/common.h ]; then grep -q "#include <cstdint>" src/common.h || sed -i "/#include \"s3fs_logger.h\"/i #include <cstdint>" src/common.h; fi; if [ -f src/threadpoolman.h ]; then grep -q "#include <pthread.h>" src/threadpoolman.h || sed -i "/#include <list>/a #include <pthread.h>" src/threadpoolman.h; fi; if [ -f src/threadpoolman.cpp ]; then sed -i "s/for(uint waitcnt = thread_list.size(); 0 < waitcnt; --waitcnt){/for(size_t waitcnt = thread_list.size(); 0 < waitcnt; --waitcnt){/" src/threadpoolman.cpp; fi'
