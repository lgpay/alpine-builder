PROJECT_NAME=ossfs
SOURCE_REPO=https://github.com/aliyun/ossfs.git
SOURCE_REF=v2.0.7
BUILD_SYSTEM=cmake
INSTALL_PREFIX=/usr
CONFIGURE_ARGS=''
BUILD_ARGS='-j$(nproc)'
INSTALL_ARGS=''
PACKAGE_DIRS='bin sbin lib lib64 include share local/bin local/lib local/lib64 local/include local/share'
APK_BUILD_DEPS='bash build-base git linux-headers cmake pkgconf tar file ca-certificates binutils patch coreutils findutils grep sed gawk perl curl libcurl curl-dev libxml2-dev fuse3-dev openssl-dev zlib-dev'
POST_CLONE_HOOK='if [ -f src/common/utils.h ]; then grep -q "#include <time.h>" src/common/utils.h || sed -i "/#include <stdint.h>/a #include <time.h>" src/common/utils.h; fi; if [ -f src/fs/inode.h ]; then grep -q "#include <sys/types.h>" src/fs/inode.h || sed -i "/#include <time.h>/a #include <sys/types.h>\n#include <sys/stat.h>" src/fs/inode.h; fi'
