PROJECT_NAME=ossfs
SOURCE_REPO=https://github.com/aliyun/ossfs.git
SOURCE_REF=v2.0.7
BUILD_SYSTEM=cmake
INSTALL_PREFIX=/usr
CONFIGURE_ARGS='-DOPENSSL_SOURCE='
BUILD_ARGS='-j$(nproc)'
INSTALL_ARGS=''
PACKAGE_DIRS='bin sbin lib lib64 include share local/bin local/lib local/lib64 local/include local/share'
APK_BUILD_DEPS='bash build-base git linux-headers cmake pkgconf tar file ca-certificates binutils patch coreutils findutils grep sed gawk perl curl libcurl curl-dev libxml2-dev fuse3-dev openssl-dev zlib-dev'
POST_CLONE_HOOK='set -eu; LIBFUSE_TARBALL="${LOCAL_LIBFUSE_TARBALL:-}"; LIBFUSE_HASH="04a5d2eca73e390f475ac785fe3d5145"; if [ -z "$LIBFUSE_TARBALL" ] && [ -n "${GITHUB_WORKSPACE:-}" ]; then CANDIDATE=$(find "$GITHUB_WORKSPACE" -type f -path "*/libfuse-*.tar.gz" | sort | tail -n 1 || true); if [ -n "$CANDIDATE" ]; then LIBFUSE_TARBALL="$CANDIDATE"; fi; fi; if [ -n "$LIBFUSE_TARBALL" ] && [ -f "$LIBFUSE_TARBALL" ]; then LIBFUSE_HASH=$(md5sum "$LIBFUSE_TARBALL" | awk '\''{print $1}'\''); cp "$LIBFUSE_TARBALL" dependencies/pre-built/libfuse/libfuse-3.16.2-linux-x86_64.tar.gz; fi; if [ -f dependencies/CMakeLists.txt ]; then sed -i "s/d84e371e77c82a2a18bec1b353633554/$LIBFUSE_HASH/" dependencies/CMakeLists.txt; sed -i "s#libfuse3.so.3.16.2#libfuse3.so.3.18.2#" dependencies/CMakeLists.txt; fi; if [ -f CMakeLists.txt ] && ! grep -q "src/common/musl_compat.cpp" CMakeLists.txt; then perl -0pi -e '\''s/add_executable\(ossfs2 \$\{ossfs2_srcs\}\)/add_executable(ossfs2 \$\{ossfs2_srcs\} src\/common\/musl_compat.cpp)/'\'' CMakeLists.txt; fi; cat > src/common/musl_compat.cpp <<'\''EOF'\''
#ifndef __GLIBC__
#include <stddef.h>
#include <stdlib.h>

extern "C" int backtrace(void **, int) {
  return 0;
}

extern "C" char **backtrace_symbols(void *const *, int) {
  return static_cast<char **>(calloc(1, sizeof(char *)));
}
#endif
EOF
if [ -f src/common/utils.h ] && ! grep -q "#include <time.h>" src/common/utils.h; then awk '\''{print} /#include <stdint.h>/ && !done {print "#include <time.h>"; done=1}'\'' src/common/utils.h > src/common/utils.h.tmp && mv src/common/utils.h.tmp src/common/utils.h; fi; if [ -f src/fs/inode.h ] && ! grep -q "#include <sys/types.h>" src/fs/inode.h; then awk '\''{print} /#include <time.h>/ && !done {print "#include <sys/types.h>"; print "#include <sys/stat.h>"; done=1}'\'' src/fs/inode.h > src/fs/inode.h.tmp && mv src/fs/inode.h.tmp src/fs/inode.h; fi; if [ -f src/fs/fs.cpp ] && ! grep -q "#include <malloc.h>" src/fs/fs.cpp; then awk '\''{print} /^#include / && !done {print "#include <malloc.h>"; done=1}'\'' src/fs/fs.cpp > src/fs/fs.cpp.tmp && mv src/fs/fs.cpp.tmp src/fs/fs.cpp; fi; if [ -f src/fs/fs.cpp ] && ! grep -q "static inline int malloc_trim(size_t)" src/fs/fs.cpp; then awk '\''{print} /^#include <fcntl.h>/ && !done {print "#ifndef __GLIBC__"; print "static inline int malloc_trim(size_t) { return 0; }"; print "#endif"; done=1}'\'' src/fs/fs.cpp > src/fs/fs.cpp.tmp && mv src/fs/fs.cpp.tmp src/fs/fs.cpp; fi; if [ -f src/main.cpp ] && ! grep -q "#include <malloc.h>" src/main.cpp; then awk '\''{print} /^#include / && !done {print "#include <malloc.h>"; done=1}'\'' src/main.cpp > src/main.cpp.tmp && mv src/main.cpp.tmp src/main.cpp; fi; if [ -f src/main.cpp ] && ! grep -q "static inline int mallopt(int, int)" src/main.cpp; then awk '\''{print} /^#include <malloc.h>/ && !done {print "#ifndef __GLIBC__"; print "#ifndef M_TRIM_THRESHOLD"; print "#define M_TRIM_THRESHOLD (-1)"; print "#endif"; print "static inline int mallopt(int, int) { return 0; }"; print "#endif"; done=1}'\'' src/main.cpp > src/main.cpp.tmp && mv src/main.cpp.tmp src/main.cpp; fi'
