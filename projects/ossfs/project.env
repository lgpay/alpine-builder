PROJECT_NAME=ossfs
SOURCE_REPO=https://github.com/aliyun/ossfs.git
SOURCE_REF=main
BUILD_SYSTEM=cmake
INSTALL_PREFIX=/usr
CONFIGURE_ARGS='-DCMAKE_INSTALL_PREFIX=/usr'
BUILD_ARGS='--parallel'
INSTALL_ARGS=''
PACKAGE_DIRS='bin sbin lib lib64 include share local/bin local/lib local/lib64 local/include local/share'
APK_BUILD_DEPS='bash build-base git linux-headers cmake ninja pkgconf tar file ca-certificates binutils patch coreutils findutils grep sed gawk perl openssl-dev'
