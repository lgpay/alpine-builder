PROJECT_NAME=libfuse
SOURCE_REPO=https://github.com/libfuse/libfuse.git
SOURCE_REF=fuse-2.9.9
BUILD_SYSTEM=autotools
INSTALL_PREFIX=/usr
CONFIGURE_ARGS='--disable-example --disable-util --disable-static'
BUILD_ARGS='-j$(nproc)'
INSTALL_ARGS=''
PACKAGE_DIRS='lib include share'
APK_BUILD_DEPS='bash build-base git linux-headers autoconf automake libtool make pkgconf tar file ca-certificates gettext-dev'
PRE_BUILD_HOOK='./makeconf.sh'
